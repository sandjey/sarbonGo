APP_ENV=local
HTTP_ADDR=:8080

# Required headers validation
CLIENT_TOKEN_EXPECTED=dev-client-token

# Postgres
DATABASE_URL=postgres://sarbon:sarbon@localhost:5432/sarbon?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT (время жизни в секундах)
# access: 900 = 15 мин; refresh: 2592000 = 30 дней
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JWT_SIGNING_KEY=change-me-in-production

# OTP
OTP_LENGTH=6
OTP_TTL_SECONDS=120
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_MAX_ATTEMPTS=5
OTP_SEND_LIMIT_PER_PHONE_PER_HOUR=10
OTP_SEND_LIMIT_PER_IP_PER_HOUR=30
OTP_SEND_WINDOW_SECONDS=3600
# Лимит попыток ввода OTP на один номер в окне (защита от подбора кода)
OTP_VERIFY_ATTEMPTS_PER_PHONE=10
OTP_VERIFY_WINDOW_SECONDS=900
# Universal OTP for all roles/flows (dev/testing). Must be numeric and same length as OTP_LENGTH.
# Example: UNIVERSAL_OTP_CODE=111111
UNIVERSAL_OTP_CODE=

# Telegram Gateway
TELEGRAM_GATEWAY_BASE_URL=https://gatewayapi.telegram.org
TELEGRAM_GATEWAY_TOKEN=put-your-token-here
TELEGRAM_GATEWAY_SENDER_ID=
TELEGRAM_GATEWAY_BYPASS=false

# Лимит грузов на одного фриланс-диспетчера (0 = без лимита)
FREELANCE_DISPATCHER_CARGO_LIMIT=0

# Cargo moderation (dev toggle)
# true  = груз после POST /api/cargo создаётся в PENDING_MODERATION и требует одобрения админом
# false = груз после POST /api/cargo создаётся сразу в SEARCHING_ALL (без модерации) — удобно для разработки
CARGO_MODERATION_ENABLED=true

# Companies moderation (dev toggle)
# true  = POST /v1/admin/companies создаёт компанию со статусом pending (как в prod), дальше нужен PATCH owner (status -> active)
# false = POST /v1/admin/companies создаёт компанию сразу active (без dev-ручного шага)
COMPANIES_MODERATION_ENABLED=true

# Calls (Voice)
# Авто-таймаут: если звонок RINGING дольше N секунд → MISSED
CALLS_RINGING_TIMEOUT_SECONDS=30
# Rate limit на создание звонков (POST /v1/calls)
CALLS_CREATE_LIMIT=6
CALLS_CREATE_WINDOW_SECONDS=60
# ICE/TURN for WebRTC clients (comma separated list)
CALLS_ICE_URLS=stun:stun.l.google.com:19302,turn:turn.sarbon.me:3478?transport=udp,turn:turn.sarbon.me:3478?transport=tcp,turns:turn.sarbon.me:5349?transport=tcp
CALLS_TURN_USERNAME=dev_backend
CALLS_TURN_CREDENTIAL=dev12345

# Firebase Push Notifications (FCM)
PUSH_NOTIFICATIONS_ENABLED=false
FIREBASE_PROJECT_ID=
# Абсолютный путь к JSON service account (файл может называться как угодно: json.json, firebase-adminsdk.json).
# Linux (проект в домашней папке): FIREBASE_CREDENTIALS_FILE=/home/dev_backend/sarbonGo/json.json
# Linux (файл в $HOME):          FIREBASE_CREDENTIALS_FILE=/home/dev_backend/json.json
# Docker: смонтируйте файл в контейнер и укажите путь ВНУТРИ контейнера, например /run/secrets/firebase.json
FIREBASE_CREDENTIALS_FILE=

